PORT=5000
# Optional: extra allowed browser origins (comma-separated). .vercel.app is allowed by default.
# CORS_ORIGINS=https://your-custom-domain.com
# FRONTEND_URL=https://your-frontend.vercel.app
# Optional. JSON body max (profile saves with several base64 images). Default 25mb if unset.
# JSON_BODY_LIMIT=25mb
# Same keys as in Clerk Dashboard → API Keys (backend needs BOTH)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxx

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_secret

# --- Delayed: photo verification (AWS Rekognition CompareFaces) —
# IAM user/policy: rekognition:CompareFaces
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# REKOGNITION_MIN_SIMILARITY=88
